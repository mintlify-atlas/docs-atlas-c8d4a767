  "keyFeatures": [
    "Unified API across OpenAI, Anthropic, Google GenAI, and Mistral",
    "Full type safety with strict TypeScript and Zod schemas",
    "Streaming support with async iterables",
    "Structured outputs with schema validation",
    "Tool/function calling with automatic JSON Schema conversion",
    "Multi-modal support for text, images, and files",
    "Embeddings and image generation",
    "Provider-specific options escape hatch"
  ],
